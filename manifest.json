{
  "manifest_version": 3,
  "name": "SubGuard",
  "version": "1.0.0",
  "description": "Track, manage, and cancel your paid subscriptions — all locally, no cloud required.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.netflix.com/*",
        "*://*.spotify.com/*",
        "*://*.hulu.com/*",
        "*://*.disneyplus.com/*",
        "*://*.hbomax.com/*",
        "*://*.max.com/*",
        "*://*.primevideo.com/*",
        "*://*.apple.com/*",
        "*://*.youtube.com/*",
        "*://*.peacocktv.com/*",
        "*://*.paramountplus.com/*",
        "*://*.crunchyroll.com/*",
        "*://*.dropbox.com/*",
        "*://*.box.com/*",
        "*://*.notion.so/*",
        "*://*.evernote.com/*",
        "*://*.slack.com/*",
        "*://*.zoom.us/*",
        "*://*.adobe.com/*",
        "*://*.figma.com/*",
        "*://*.canva.com/*",
        "*://*.github.com/*",
        "*://*.atlassian.com/*",
        "*://*.monday.com/*",
        "*://*.asana.com/*",
        "*://*.trello.com/*",
        "*://*.duolingo.com/*",
        "*://*.coursera.org/*",
        "*://*.udemy.com/*",
        "*://*.skillshare.com/*",
        "*://*.masterclass.com/*",
        "*://*.peloton.com/*",
        "*://*.calm.com/*",
        "*://*.headspace.com/*",
        "*://*.nytimes.com/*",
        "*://*.wsj.com/*",
        "*://*.medium.com/*",
        "*://*.grammarly.com/*",
        "*://*.lastpass.com/*",
        "*://*.1password.com/*"
      ],
      "js": ["src/content/detector.ts"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "options_ui": {
    "page": "src/onboarding/index.html",
    "open_in_tab": true
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "identity",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "*://*.netflix.com/*",
    "*://*.spotify.com/*",
    "*://*.hulu.com/*",
    "*://*.disneyplus.com/*",
    "*://*.hbomax.com/*",
    "*://*.max.com/*",
    "*://*.primevideo.com/*",
    "*://*.apple.com/*",
    "*://*.youtube.com/*",
    "*://*.peacocktv.com/*",
    "*://*.paramountplus.com/*",
    "*://*.crunchyroll.com/*",
    "*://*.dropbox.com/*",
    "*://*.box.com/*",
    "*://*.notion.so/*",
    "*://*.evernote.com/*",
    "*://*.slack.com/*",
    "*://*.zoom.us/*",
    "*://*.adobe.com/*",
    "*://*.figma.com/*",
    "*://*.canva.com/*",
    "*://*.github.com/*",
    "*://*.atlassian.com/*",
    "*://*.monday.com/*",
    "*://*.asana.com/*",
    "*://*.trello.com/*",
    "*://*.duolingo.com/*",
    "*://*.coursera.org/*",
    "*://*.udemy.com/*",
    "*://*.skillshare.com/*",
    "*://*.masterclass.com/*",
    "*://*.peloton.com/*",
    "*://*.calm.com/*",
    "*://*.headspace.com/*",
    "*://*.nytimes.com/*",
    "*://*.wsj.com/*",
    "*://*.medium.com/*",
    "*://*.grammarly.com/*",
    "*://*.lastpass.com/*",
    "*://*.1password.com/*",
    "https://api.lemonsqueezy.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["service-logos/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
